DefaultDependencies=no


Before=initrd-root-fs.target initrd-switch-root.target
Wants=initrd-root-device.target
After=systemd-udevd.service

exec=/bin/sh -c "mkdir -p /run/lrescue/iso /sysroot && mount -t iso9660 -o ro /dev/disk/by-label/LRESCUEISO /run/lrescue/iso && mount -t squashfs -o ro,loop /run/lrescue/iso/rootfs.squashfs /sysroot"


[Install]
WantedBy=initrd-root-fs.target
